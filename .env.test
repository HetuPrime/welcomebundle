# WelcomeBundle Configuration
# Copy this file to .env and fill in your values

# ============================================
# 测试模式（不会实际注册账号）
# ============================================
DRY_RUN=true

# ============================================
# 宝宝信息（出生前填写）
# ============================================
BABY_NAME=TestBaby
LAST_NAME=Test
BABY_DOB=2024-06-01

# ============================================
# 父母联系方式
# ============================================
PARENT_EMAIL=test@example.com

# ============================================
# 平台选择（可选）
# ============================================
# 方式 1: 指定要启用的平台（逗号分隔）
# ENABLED_PLATFORMS=github,reddit,steam,epic_games
ENABLED_PLATFORMS=github,reddit

# 方式 2: 指定要禁用的平台（逗号分隔）
# DISABLED_PLATFORMS=battlenet,nintendo
# 注意：ENABLED_PLATFORMS 优先级高于 DISABLED_PLATFORMS

# ============================================
# 安全配置
# ============================================
# 加密密钥，用于保存账号凭证
# 生成命令: openssl rand -base64 32
ENCRYPTION_KEY=test-encryption-key-32-characters!!

# ============================================
# Telegram Bot（测试时可跳过）
# ============================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
