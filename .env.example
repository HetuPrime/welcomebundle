# WelcomeBundle Configuration
# Copy this file to .env and fill in your values

# ============================================
# 宝宝信息（出生前填写）
# ============================================
BABY_NAME=
BABY_EXPECTED_DATE=
BABY_DOB=

# ============================================
# 父母联系方式
# ============================================
PARENT_EMAIL=
LAST_NAME=

# ============================================
# 安全配置
# ============================================
# 加密密钥，用于保存账号凭证
# 生成命令: openssl rand -base64 32
ENCRYPTION_KEY=

# ============================================
# Telegram Bot（可选，用于远程触发）
# ============================================
# 1. 在 Telegram 找 @BotFather
# 2. 发送 /newbot 创建机器人
# 3. 获取 Bot Token 填在下面
TELEGRAM_BOT_TOKEN=

# 4. 发消息给你的 Bot
# 5. 访问 https://api.telegram.org/bot<TOKEN>/getUpdates
# 6. 找到 "chat":{"id":123456789} 中的数字
TELEGRAM_CHAT_ID=

# ============================================
# Webhook（可选，用于远程触发）
# ============================================
WEBHOOK_SECRET=
WEBHOOK_PORT=3000
