# WelcomeBundle Configuration
# Copy this file to .env and fill in your values

# ============================================
# 运行模式
# ============================================
DRY_RUN=true

# ============================================
# 孩子的信息
# ============================================
BABY_NAME=Emma
LAST_NAME=Smith
BABY_DOB=2024-06-01

# ============================================
# 孩子的专用邮箱（用于注册所有平台）
# ============================================
# 创建一个 Gmail 给孩子，如：emma2024@gmail.com
PARENT_EMAIL=emma2024@gmail.com

# ============================================
# Gmail IMAP 配置（自动验证邮件）
# ============================================
# 1. 访问 https://myaccount.google.com/apppasswords
# 2. 选择"邮件" → "其他(WelcomeBundle)"
# 3. 复制生成的 16 位密码
EMAIL_PROVIDER=gmail
EMAIL_USER=emma2024@gmail.com
EMAIL_PASSWORD=abcd efgh ijkl mnop

# ============================================
# 平台选择
# ============================================
# 指定要注册的平台（逗号分隔）
ENABLED_PLATFORMS=github,steam,reddit,epic_games

# 可用平台: github, gitlab, steam, epic_games,
#          battlenet, nintendo, reddit, medium
# 默认: github, steam, epic_games

# ============================================
# 安全配置
# ============================================
# 加密密钥，用于保存账号凭证
# 生成命令: openssl rand -base64 32
ENCRYPTION_KEY=

# ============================================
# Telegram Bot（可选，用于远程触发）
# ============================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
