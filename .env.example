# WelcomeBundle Configuration
# Copy this file to .env and fill in your values

# ============================================
# 宝宝信息（出生前填写）
# ============================================
BABY_NAME=
BABY_EXPECTED_DATE=
BABY_DOB=
LAST_NAME=

# ============================================
# 父母联系方式
# ============================================
# 使用真实邮箱接收验证链接
PARENT_EMAIL=

# 使用临时邮箱自动处理验证（可选）
USE_TEMP_EMAIL=false

# ============================================
# 平台选择（可选）
# ============================================
# 方式 1: 指定要启用的平台（逗号分隔）
# ENABLED_PLATFORMS=github,steam,reddit,epic_games
ENABLED_PLATFORMS=

# 方式 2: 指定要禁用的平台（逗号分隔）
# DISABLED_PLATFORMS=battlenet,nintendo
# 注意：ENABLED_PLATFORMS 优先级高于 DISABLED_PLATFORMS
DISABLED_PLATFORMS=

# 可用平台列表:
# - github      (开发者平台)
# - gitlab      (开发者平台)
# - steam       (游戏平台)
# - epic_games  (游戏平台，Fortnite 等)
# - battlenet   (游戏平台，魔兽世界、守望先锋)
# - nintendo    (游戏平台，Switch)
# - reddit      (社区)
# - medium      (博客)

# 默认启用: github, steam, epic_games

# ============================================
# 安全配置
# ============================================
# 加密密钥，用于保存账号凭证
# 生成命令: openssl rand -base64 32
ENCRYPTION_KEY=

# ============================================
# Telegram Bot（可选，用于远程触发）
# ============================================
# 1. 在 Telegram 找 @BotFather
# 2. 发送 /newbot 创建机器人
# 3. 获取 Bot Token 填在下面
TELEGRAM_BOT_TOKEN=

# 4. 发消息给你的 Bot
# 5. 访问 https://api.telegram.org/bot<TOKEN>/getUpdates
# 6. 找到 "chat":{"id":123456789} 中的数字
TELEGRAM_CHAT_ID=

# ============================================
# Webhook（可选，用于远程触发）
# ============================================
WEBHOOK_SECRET=
WEBHOOK_PORT=3000
