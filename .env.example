# WelcomeBundle Configuration
# Copy this file to .env and fill in your values

# ============================================
# 运行模式
# ============================================
# DRY_RUN=true  - 模拟模式，不会实际注册
# DRY_RUN=false - 实际执行注册
DRY_RUN=true

# ============================================
# 宝宝信息（出生前填写）
# ============================================
BABY_NAME=TestBaby
LAST_NAME=Test
BABY_DOB=2024-06-01

# ============================================
# 父母联系方式
# ============================================
# 用于接收验证邮件的真实邮箱
PARENT_EMAIL=your-real-email@example.com

# ============================================
# 平台选择
# ============================================
# 指定要启用的平台（逗号分隔）
ENABLED_PLATFORMS=github,reddit

# 可用平台: github, gitlab, steam, epic_games, battlenet, nintendo, reddit, medium
# 默认: github, steam, epic_games

# ============================================
# 邮箱验证方式
# ============================================
# 方式 1: 临时邮箱（默认，无需配置）
# - 自动创建临时邮箱接收验证码
# - 某些平台可能不接受临时邮箱

# 方式 2: IMAP 邮箱（推荐）
# - 连接你的真实邮箱自动读取验证邮件
# - 支持 Gmail, Outlook, Yahoo

# Gmail 配置示例:
# EMAIL_PROVIDER=gmail
# EMAIL_USER=yourname@gmail.com
# EMAIL_PASSWORD=abcd efgh ijkl mnop  # App Password，不是 Gmail 密码

# Outlook 配置示例:
# EMAIL_PROVIDER=outlook
# EMAIL_USER=yourname@outlook.com
# EMAIL_PASSWORD=your-password

# ============================================
# 安全配置
# ============================================
# 加密密钥，用于保存账号凭证
# 生成命令: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key-32-chars!!

# ============================================
# Telegram Bot（可选）
# ============================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
