# WelcomeBundle Configuration
# Copy this file to .env and fill in your values

# Baby Information (filled before birth)
BABY_NAME=
BABY_EXPECTED_DATE=

# Parent Contact
PARENT_EMAIL=

# Encryption key for storing credentials
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Telegram Bot (optional, for notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook secret (optional, for trigger)
WEBHOOK_SECRET=
