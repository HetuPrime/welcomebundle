{
  "name": "welcomebundle",
  "version": "2.0.0",
  "description": "🎁 A digital birth gift for your newborn - register accounts, create birth certificates, and preserve time capsules",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "register": "ts-node src/index.ts",
    "bot": "ts-node src/bot.ts",
    "proof": "ts-node src/cli-proof.ts",
    "capsule": "ts-node src/cli-capsule.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:local": "chmod +x test-local.sh && ./test-local.sh",
    "deploy": "chmod +x deploy.sh && ./deploy.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HetuPrime/welcomebundle.git"
  },
  "keywords": [
    "baby",
    "gift",
    "birth-certificate",
    "time-capsule",
    "account",
    "registration",
    "gaming",
    "steam",
    "github"
  ],
  "author": "HetuPrime",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/HetuPrime/welcomebundle/issues"
  },
  "homepage": "https://github.com/HetuPrime/welcomebundle#readme",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.3",
    "jest": "^29.7.0",
    "playwright": "^1.58.2",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "imapflow": "^1.0.162",
    "mailparser": "^3.7.1",
    "node-fetch": "^2.7.0",
    "node-telegram-bot-api": "^0.66.0",
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "canvas": "^2.11.2"
  }
}
